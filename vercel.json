{
    "version": 2,
    "buildCommand": "npm run build",
    "devCommand": "npm run start",
    "installCommand": "npm install --include=dev",
    "framework": null,
    "outputDirectory": "dashboard/dist",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api"
        },
        {
            "source": "/gatekeeper/:path*",
            "destination": "/api"
        },
        {
            "source": "/health",
            "destination": "/api"
        }
    ],
    "headers": [
        {
            "source": "/api/:path*",
            "headers": [
                {
                    "key": "Access-Control-Allow-Credentials",
                    "value": "true"
                },
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization, X-Agent-ID, X-Agent-Signature, X-Auth-Timestamp"
                }
            ]
        }
    ]
}