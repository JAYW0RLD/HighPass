{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "src/server.ts"
        },
        {
            "source": "/gatekeeper/(.*)",
            "destination": "src/server.ts"
        },
        {
            "source": "/health",
            "destination": "src/server.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/dashboard/$1"
        }
    ],
    "redirects": [
        {
            "source": "/dashboard",
            "destination": "/",
            "permanent": true
        }
    ]
}