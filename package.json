{
  "name": "x402-gatekeeper",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "./node_modules/.bin/tsc && cd dashboard && npm install && npm run build",
    "build:backend": "./node_modules/.bin/tsc",
    "build:frontend": "cd dashboard && npm run build",
    "vercel-build": "npm run build",
    "start": "node dist/src/server.js",
    "dev": "ts-node src/server.ts",
    "deploy:cronos": "node dist/scripts/deploy-cronos.js",
    "verify:cronos": "node dist/scripts/simulate_cronos.js",
    "demo": "node dist/scripts/run_demo.js",
    "request": "bash scripts/request.sh",
    "test:node": "anvil --fork-url https://testnet.zkevm.cronos.org --chain-id 240 --port 8545",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "test:coverage": "npx jest --coverage",
    "lint": "npx eslint . --ext .ts",
    "lint:fix": "npx eslint . --ext .ts --fix",
    "format": "npx prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "npx prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "axios": "^1.13.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@pythnetwork/hermes-client": "^2.0.0",
    "@supabase/supabase-js": "^2.90.0",
    "@types/sqlite3": "^3.1.11",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
