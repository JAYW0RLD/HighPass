# Server Configuration
PORT=3000
NODE_ENV=development

# Blockchain
RPC_URL=https://rpc-t3.cronos-zkevm.org
CHAIN_ID=240
# Private Key for Admin Ops (Optional for read-only)
PRIVATE_KEY=0x...

# Contracts
PAYMENT_HANDLER_ADDRESS=0x7a3642780386762391262d0577908D5950882e39
IDENTITY_CONTRACT_ADDRESS=0x...

# Supabase (Database & Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=ey...
# REQUIRED: Service Role Key (DO NOT USE ANON_KEY for backend operations)
SUPABASE_SERVICE_ROLE_KEY=sbp_service_...

# CORS (Frontend Hosts)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-app.vercel.app
